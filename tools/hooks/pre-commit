#!/usr/bin/env bash
# Canon gate (Island Mountain) — staged-only, fast.
#   BLOCK: NUL/truncation (§I.9), missing </html>, private keys / vault tokens (§I.8)
#   WARN:  AWS-key-shaped strings, in-file AI-attribution artifacts (§I.3)
#          (WARN, not BLOCK — this is a content site; example creds appear in articles)
set -uo pipefail
FAIL=0
# Skip the hook sources themselves in content scans — they carry these patterns by design.
scan_content() { case "$1" in tools/hooks/*) return 1;; *) return 0;; esac; }

while IFS= read -r -d '' f; do
  [ -f "$f" ] || continue

  # --- §I.9 truncation / NUL — scan KNOWN TEXT types ONLY (an allowlist, not a binary
  #     denylist). Inverting it means an unlisted binary (.wasm/.avif/.heic/.pack/a
  #     no-extension blob) can never be mis-read as a "truncated" text file and clap
  #     an otherwise-fine commit. Unknown extension => treated as binary => skipped. ---
  case "${f,,}" in
    *.html|*.htm|*.css|*.js|*.mjs|*.cjs|*.jsx|*.ts|*.tsx|*.json|*.jsonc|*.md|*.markdown|*.txt|*.xml|*.svg|*.yml|*.yaml|*.toml|*.csv|*.rs|*.py|*.sh|*.bash|*.ps1|*.c|*.h|*.go|*.rb|*.java|*.sql|*.map)
      if [ "$(LC_ALL=C tr -cd '\0' < "$f" | wc -c)" -gt 0 ]; then
        echo "BLOCK  NUL bytes (truncation): $f" >&2; FAIL=1
      fi ;;
  esac
  # Only a file that PRESENTS as a full HTML document (<!doctype html>/<html…>) yet
  # lacks its closing tag is truncated. Genuine partials/includes/fragments have no
  # <html> root and are left alone — they must never clap a commit.
  case "${f,,}" in
    google*.html|*/google*.html) ;;
    *.html|*.htm)
      if grep -qiE '<!doctype html|<html' "$f" && ! grep -qi '</html>' "$f"; then
        echo "BLOCK  missing </html> (truncated full document): $f" >&2; FAIL=1
      fi ;;
  esac

  if scan_content "$f"; then
    # --- §I.8 high-confidence secrets ---
    if LC_ALL=C grep -Eq -- '-----BEGIN ([A-Z ]+ )?PRIVATE KEY-----|hv[sb]\.[A-Za-z0-9_-]{20,}' "$f"; then
      echo "BLOCK  possible private key / vault token: $f" >&2; FAIL=1
    fi
    # --- WARN-only (FP-prone on a content site) ---
    if LC_ALL=C grep -Eq -- 'AKIA[0-9A-Z]{16}' "$f"; then
      echo "WARN   AWS-key-shaped string (example creds ok): $f" >&2
    fi
    if LC_ALL=C grep -Eq -- 'Co-Authored-By: *Claude|Generated with \[?Claude Code' "$f"; then
      echo "WARN   AI-attribution artifact in file content: $f" >&2
    fi
  fi
done < <(git diff --cached -z --name-only --diff-filter=ACM)

# Structural HTML/navigation gate reads the staged index, not unstaged working copies.
HTML_GATE="$(git rev-parse --show-toplevel)/tools/html-structure-gate.py"
PYTHON_BIN="$(command -v python3 2>/dev/null || command -v python 2>/dev/null || true)"
if [ -f "$HTML_GATE" ] && [ -n "$PYTHON_BIN" ]; then
  "$PYTHON_BIN" "$HTML_GATE" staged || FAIL=1
else
  # Tooling-safe fallback blocks the exact high-confidence corruption classes.
  while IFS= read -r -d '' f; do
    [ -f "$f" ] || continue
    if LC_ALL=C grep -Eq -- 'bout\.html>About</a></li>/a|</li>/a[[:space:]]*<li|href=[^"'"'"'[:space:]>]' "$f"; then
      echo "BLOCK  malformed HTML/navigation fallback signature: $f" >&2; FAIL=1
    fi
    while IFS= read -r endpoint; do
      case "$endpoint" in
        https://formsubmit.co/basho@islandmountain.io) ;;
        *) echo "BLOCK  unapproved FormSubmit endpoint in $f: $endpoint" >&2; FAIL=1 ;;
      esac
    done < <(LC_ALL=C grep -Eio -- 'https://formsubmit\.co/[^"'"'"'[:space:]<>]+' "$f" || true)
  done < <(git diff --cached -z --name-only --diff-filter=ACM -- '*.html')
fi

# --- CANON §11 no-slop gate: block newly-added build-process artifacts ---
SLOP_SCAN="$(git rev-parse --show-toplevel)/tools/no-slop-scan.sh"
if [ -x "$SLOP_SCAN" ]; then
  "$SLOP_SCAN" staged || echo "WARN   no-slop findings (loosened to warn-only; not blocking)" >&2
fi

[ "$FAIL" -eq 0 ] || { echo "pre-commit: canon checks failed (§I.2). Fix, or override with --no-verify (discouraged)." >&2; exit 1; }
exit 0
