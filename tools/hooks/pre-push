#!/usr/bin/env bash
# Canon §I.9 — refuse to publish truncated/corrupt HTML (site-wide gate).
set -uo pipefail
FAIL=0
while IFS= read -r f; do
  [ -f "$f" ] || continue
  [ "$(LC_ALL=C tr -cd '\0' < "$f" | wc -c)" -gt 0 ] && { echo "BLOCK  NUL bytes: $f" >&2; FAIL=1; }
  # Full HTML documents only: a <html>/<!doctype> root without a closing tag is
  # truncated. Partials/includes (no root) are legitimate and never block a push.
  case "${f,,}" in
    google*.html|*/google*.html) ;;
    *) if grep -qiE '<!doctype html|<html' "$f" && ! grep -qi '</html>' "$f"; then
         echo "BLOCK  missing </html> (truncated full document): $f" >&2; FAIL=1
       fi ;;
  esac
done < <(git ls-files '*.html')

# Structural HTML/navigation gate across the complete tracked site.
HTML_GATE="$(git rev-parse --show-toplevel)/tools/html-structure-gate.py"
PYTHON_BIN="$(command -v python3 2>/dev/null || command -v python 2>/dev/null || true)"
if [ -f "$HTML_GATE" ] && [ -n "$PYTHON_BIN" ]; then
  "$PYTHON_BIN" "$HTML_GATE" full || FAIL=1
else
  # Tooling-safe fallback blocks the exact high-confidence corruption class.
  while IFS= read -r f; do
    [ -f "$f" ] || continue
    if LC_ALL=C grep -Eq -- 'bout\.html>About</a></li>/a|</li>/a[[:space:]]*<li|href=[^"'"'"'[:space:]>]' "$f"; then
      echo "BLOCK  malformed HTML/navigation fallback signature: $f" >&2; FAIL=1
    fi
  done < <(git ls-files '*.html')
fi
# --- CANON §11 no-slop gate: full-tree scan, zero artifacts may publish ---
SLOP_SCAN="$(git rev-parse --show-toplevel)/tools/no-slop-scan.sh"
if [ -x "$SLOP_SCAN" ]; then
  "$SLOP_SCAN" full >&2 || echo "WARN   no-slop findings (loosened to warn-only; not blocking)" >&2
fi

[ "$FAIL" -eq 0 ] || { echo "pre-push: truncated/corrupt HTML — refusing to publish (§I.9)." >&2; exit 1; }
exit 0
